# EmailJS Configuration - Account 1 (Customer Emails)
# Get these values from https://dashboard.emailjs.com/
# This account handles: Booking Confirmation & Payment Confirmed emails

# EmailJS Service ID for Account 1 (from Email Services tab)
VITE_EMAILJS_SERVICE_ID_1=your_service_id_here

# EmailJS Public Key for Account 1 (from Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY_1=your_public_key_here

# Template IDs for Account 1
VITE_EMAILJS_TEMPLATE_BOOKING_CONFIRMATION=your_booking_confirmation_template_id
VITE_EMAILJS_TEMPLATE_PAYMENT_CONFIRMED=your_payment_confirmed_template_id

# EmailJS Configuration - Account 2 (Admin & Rejection Emails)
# This account handles: Payment Rejected & Admin Notification emails

# EmailJS Service ID for Account 2 (from Email Services tab)
VITE_EMAILJS_SERVICE_ID_2=your_service_id_here

# EmailJS Public Key for Account 2 (from Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY_2=your_public_key_here

# Template IDs for Account 2
VITE_EMAILJS_TEMPLATE_PAYMENT_REJECTED=your_payment_rejected_template_id
VITE_EMAILJS_TEMPLATE_ADMIN_NOTIFICATION=your_admin_notification_template_id

# Admin email address for receiving new booking notifications
VITE_ADMIN_EMAIL=admin@savannaethiopiatravel.com

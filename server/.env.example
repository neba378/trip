PORT=5000

# --- Auth ---
# Long random string used to sign admin JWTs. The server refuses to start if this
# is missing or shorter than 32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# First-admin bootstrap. Used ONLY when the users table is empty (first run).
# Log in with these, then change the password / add real accounts in the Admin panel.
ADMIN_EMAIL=admin@savannaethiopiatravel.com
ADMIN_PASSWORD=change-this-strong-password

# --- CORS ---
# Comma-separated list of allowed frontend origins. Set to your real domain in production.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Email (optional, nodemailer) ---
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

NODE_ENV=development
